# Copy this to secrets.toml and fill in values for full functionality
# In Demo mode (Streamlit Cloud without credentials), execution is disabled

[aws]
access_key_id = "YOUR_ACCESS_KEY"
secret_access_key = "YOUR_SECRET_KEY"
region = "us-east-1"

[deepseek]
api_key = "YOUR_QIANWEN_API_KEY"

[deepseek_real]
api_key = "YOUR_DEEPSEEK_REAL_API_KEY"
